{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4wall.local/schemas/mission-meta.schema.json",
  "title": "MissionMeta",
  "type": "object",
  "required": [
    "missionId",
    "bundleVersion",
    "generatedAt",
    "routeMode",
    "operatingProfile",
    "launchPoint",
    "waypointCount",
    "implicitReturnToLaunch",
    "defaultAltitudeMeters",
    "defaultSpeedMetersPerSecond",
    "landingPolicy",
    "safetyDefaults",
    "artifacts"
  ],
  "properties": {
    "missionId": { "type": "string", "minLength": 1 },
    "bundleVersion": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string" },
    "routeMode": { "type": "string", "const": "road_network_following" },
    "operatingProfile": {
      "type": "string",
      "enum": ["outdoor_gps_patrol", "indoor_no_gps"]
    },
    "launchPoint": {
      "type": "object",
      "required": ["launchPointId", "location"],
      "properties": {
        "launchPointId": { "type": "string", "minLength": 1 },
        "location": {
          "type": "object",
          "required": ["lat", "lng"],
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "label": { "type": "string" }
      }
    },
    "waypointCount": { "type": "integer", "minimum": 0 },
    "implicitReturnToLaunch": { "type": "boolean", "const": true },
    "defaultAltitudeMeters": { "type": "number", "exclusiveMinimum": 0 },
    "defaultSpeedMetersPerSecond": { "type": "number", "exclusiveMinimum": 0 },
    "landingPolicy": { "type": "string", "minLength": 1 },
    "safetyDefaults": {
      "type": "object",
      "required": ["onSemanticTimeout", "onBatteryCritical", "onFrameDrop"],
      "properties": {
        "onSemanticTimeout": { "type": "string" },
        "onBatteryCritical": { "type": "string" },
        "onFrameDrop": { "type": "string" }
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["missionKmz", "missionMeta"],
      "properties": {
        "missionKmz": { "$ref": "#/$defs/artifactDescriptor" },
        "missionMeta": { "$ref": "#/$defs/artifactDescriptor" }
      }
    },
    "legacyInspectionViewpointCount": { "type": "integer", "minimum": 0 }
  },
  "$defs": {
    "artifactDescriptor": {
      "type": "object",
      "required": ["downloadUrl", "version", "checksumSha256", "contentType", "sizeBytes", "cacheControl"],
      "properties": {
        "downloadUrl": { "type": "string", "minLength": 1 },
        "version": { "type": "integer", "minimum": 1 },
        "checksumSha256": { "type": "string", "minLength": 1 },
        "contentType": { "type": "string", "minLength": 1 },
        "sizeBytes": { "type": "integer", "minimum": 0 },
        "cacheControl": { "type": "string", "minLength": 1 }
      }
    }
  }
}
