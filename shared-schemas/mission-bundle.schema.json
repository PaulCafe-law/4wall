{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4wall.local/schemas/mission-bundle.schema.json",
  "title": "MissionBundle",
  "type": "object",
  "required": [
    "missionId",
    "routeMode",
    "bundleVersion",
    "corridorSegments",
    "verificationPoints",
    "inspectionViewpoints",
    "defaultAltitudeMeters",
    "defaultSpeedMetersPerSecond",
    "artifacts",
    "verification",
    "failsafe"
  ],
  "properties": {
    "missionId": { "type": "string", "minLength": 1 },
    "routeMode": { "type": "string", "const": "road_network_following" },
    "bundleVersion": { "type": "string", "minLength": 1 },
    "corridorSegments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["segmentId", "polyline", "halfWidthMeters", "suggestedAltitudeMeters", "suggestedSpeedMetersPerSecond"],
        "properties": {
          "segmentId": { "type": "string", "minLength": 1 },
          "polyline": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["lat", "lng"],
              "properties": {
                "lat": { "type": "number" },
                "lng": { "type": "number" }
              }
            }
          },
          "halfWidthMeters": { "type": "number", "exclusiveMinimum": 0 },
          "suggestedAltitudeMeters": { "type": "number", "exclusiveMinimum": 0 },
          "suggestedSpeedMetersPerSecond": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    },
    "verificationPoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["verificationPointId", "location", "expectedOptions", "timeoutMillis"],
        "properties": {
          "verificationPointId": { "type": "string", "minLength": 1 },
          "location": {
            "type": "object",
            "required": ["lat", "lng"],
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          },
          "expectedOptions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "timeoutMillis": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "inspectionViewpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["inspectionViewpointId", "location", "yawDegrees", "captureMode", "label"],
        "properties": {
          "inspectionViewpointId": { "type": "string", "minLength": 1 },
          "location": {
            "type": "object",
            "required": ["lat", "lng"],
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          },
          "yawDegrees": { "type": "number" },
          "captureMode": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 }
        }
      }
    },
    "defaultAltitudeMeters": { "type": "number", "exclusiveMinimum": 0 },
    "defaultSpeedMetersPerSecond": { "type": "number", "exclusiveMinimum": 0 },
    "artifacts": {
      "type": "object",
      "required": ["missionKmz", "missionMeta"],
      "properties": {
        "missionKmz": { "$ref": "#/$defs/artifact" },
        "missionMeta": { "$ref": "#/$defs/artifact" }
      }
    },
    "verification": {
      "type": "object",
      "required": ["schemaMajor", "missionMetaPresent", "missionKmzPresent", "missionMetaChecksumVerified", "missionKmzChecksumVerified"],
      "properties": {
        "schemaMajor": { "type": "integer", "minimum": 1 },
        "missionMetaPresent": { "type": "boolean" },
        "missionKmzPresent": { "type": "boolean" },
        "missionMetaChecksumVerified": { "type": "boolean" },
        "missionKmzChecksumVerified": { "type": "boolean" }
      }
    },
    "failsafe": {
      "type": "object",
      "required": ["onSemanticTimeout", "onBatteryCritical", "onFrameDrop"],
      "properties": {
        "onSemanticTimeout": { "type": "string" },
        "onBatteryCritical": { "type": "string" },
        "onFrameDrop": { "type": "string" }
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "required": ["name", "localPath", "checksum", "version", "sizeBytes"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "localPath": { "type": "string", "minLength": 1 },
        "checksum": { "type": "string", "minLength": 1 },
        "version": { "type": "integer", "minimum": 1 },
        "sizeBytes": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
